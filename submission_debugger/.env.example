# Required: dataset root directory
SD_DATASET_DIR=/data/accident_dataset

# Optional: python interpreter (must be Python 3.10+)
# PYTHON_BIN=/opt/conda/envs/qwen35/bin/python

# Admin bootstrap account (created once on empty DB)
SD_ADMIN_USER=admin
SD_ADMIN_PASS=change-this-now

# App runtime
SD_HOST=127.0.0.1
SD_PORT=18080
SD_WORKERS=2
SD_RELOAD=0

# If behind reverse proxy (recommended)
SD_PROXY_HEADERS=1
SD_FORWARDED_ALLOW_IPS=127.0.0.1
SD_COOKIE_SECURE=1
